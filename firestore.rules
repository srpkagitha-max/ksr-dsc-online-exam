rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){ return request.auth != null; }
    function isSuper(){ return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superAdmin'; }
    function isInstituteAdmin(inst){ return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteCode == inst; }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isSuper());
      allow write: if isSuper() || request.auth.uid == uid;
    }
    match /institutes/{code} {
      allow read: if signedIn() || resource.data.public == true;
      allow write: if isSuper() || isInstituteAdmin(code);
      match /exams/{examId} {
        allow read: if true;
        allow write: if isSuper() || isInstituteAdmin(code);
      }
      match /students/{studentId} {
        allow read, write: if true;
      }
      match /results/{resultId} {
        allow read: if true;
        allow write: if true;
      }
    }
  }
}
